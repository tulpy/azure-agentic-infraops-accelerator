{
  "name": "Agentic InfraOps",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "installBicep": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13",
      "installTools": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "tflint": "0.61.0",
      "installTFsec": false
    },
    "ghcr.io/devcontainers/features/go:1": {}
  },

  // Lifecycle commands - chain apt operations to avoid lock conflicts
  "onCreateCommand": "set -e; sudo rm -f /etc/apt/sources.list.d/yarn.list 2>/dev/null; sudo apt-get update; sudo apt-get install -y graphviz dos2unix; ARCH=$(dpkg --print-architecture); if [ \"$ARCH\" = \"amd64\" ]; then curl -fsSL https://dl.k6.io/key.gpg | sudo gpg --dearmor -o /usr/share/keyrings/k6-archive-keyring.gpg; echo 'deb [signed-by=/usr/share/keyrings/k6-archive-keyring.gpg] https://dl.k6.io/deb stable main' | sudo tee /etc/apt/sources.list.d/k6.list; sudo apt-get update; sudo apt-get install -y k6; else echo \"Skipping k6 install on unsupported architecture: $ARCH\"; fi; curl -LsSf https://astral.sh/uv/install.sh | sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": {
    "lefthook": "npx lefthook install 2>/dev/null || true",
    "update-tools": "bash .devcontainer/post-start.sh"
  },

  // Environment variables for Python optimization
  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "UV_CACHE_DIR": "/home/vscode/.cache/uv",
    "TF_PLUGIN_CACHE_DIR": "/home/vscode/.terraform.d/plugin-cache"
  },

  "remoteEnv": {
    "AZURE_DEFAULTS_LOCATION": "swedencentral",
    // Pass GH_TOKEN from host → container. gh CLI uses it automatically, no `gh auth login` needed.
    // Each user sets this once in VS Code User Settings (Ctrl+,):
    //   "terminal.integrated.env.linux": { "GH_TOKEN": "ghp_yourTokenHere" }
    // This is the ONLY supported method — shell exports (.bashrc/.profile) do NOT propagate reliably.
    // Value is empty string if not set — gh CLI falls back to its normal auth flow.
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-bicep",
        "ms-vscode.powershell",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "davidanson.vscode-markdownlint",
        "ms-vscode.copilot-mermaid-diagram",
        "ms-vscode.azurecli",
        "ms-azuretools.vscode-azurecontainerapps",
        "ms-azuretools.vscode-azurestaticwebapps",
        "ms-azuretools.azure-dev",
        "ms-azuretools.vscode-containers",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-kubernetes-tools.vscode-aks-tools",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "ms-azuretools.vscode-azure-mcp-server",
        "esbenp.prettier-vscode",
        "mechatroner.rainbow-csv",
        "redhat.vscode-yaml",
        "mutantdino.resourcemonitor",
        "HashiCorp.terraform",
        "ms-azuretools.vscode-azureterraform"
      ],
      "settings": {
        "chat.customAgentInSubagent.enabled": true,
        "chat.agentFilesLocations": {
          ".github/agents": true,
          ".github/agents/_subagents": true
        },
        "chat.agentSkillsLocations": {
          ".github/skills": true
        },
        "chat.useAgentSkills": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.rulers": [120],
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 120,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n",
        "editor.tabSize": 2,
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.rulers": [120],
          "editor.wordWrap": "wordWrapColumn",
          "editor.wordWrapColumn": 120
        },
        "[bicep]": {
          "editor.tabSize": 2
        },
        "[terraform]": {
          "editor.tabSize": 2,
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[powershell]": {
          "editor.tabSize": 4
        },
        "[python]": {
          "editor.tabSize": 4
        },
        "python.defaultInterpreterPath": "/usr/local/python/current/bin/python3",
        "python.analysis.typeCheckingMode": "basic",
        "markdownlint.config": {
          "extends": "${workspaceFolder}/.markdownlint-cli2.jsonc"
        },
        "markdownlint.run": "onSave"
      }
    }
  },

  // Mounts for credential/cache persistence across rebuilds
  // - Azure CLI: Host's ~/.azure (Linux/macOS) or %USERPROFILE%\.azure (Windows)
  // - GitHub CLI: Docker volume (Windows uses keyring, can't be mounted; Linux/macOS use files)
  // - UV cache: Docker volume for Python package cache
  "mounts": [
    {
      "source": "${localEnv:USERPROFILE}${localEnv:HOME}/.azure",
      "target": "/home/vscode/.azure",
      "type": "bind"
    },
    {
      "source": "devcontainer-gh-config-${devcontainerId}",
      "target": "/home/vscode/.config/gh",
      "type": "volume"
    },
    {
      "source": "devcontainer-uv-cache-${devcontainerId}",
      "target": "/home/vscode/.cache/uv",
      "type": "volume"
    }
  ],

  "remoteUser": "vscode"
}
